{
  "name": "AI Dev Platform",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:0-20",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "bash ./.devcontainer/post-create.sh",
  "remoteUser": "node",
  "updateRemoteUserUID": true,
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "VisualStudioExptTeam.vscodeintellicode",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.profiles.linux": {
          "bash (onboard)": {
            "path": "/bin/bash",
            "args": [
              "-lc",
              "WORKSPACE_DIR=\"${DEVCONTAINER_WORKSPACE_FOLDER:-/workspaces/ai-dev-platform}\"; if [ ! -f \"$WORKSPACE_DIR/.onboarding_complete\" ]; then bash \"$WORKSPACE_DIR/scripts/onboard.sh\"; fi; exec bash"
            ],
            "overrideName": true
          },
          "bash": {
            "path": "/bin/bash",
            "args": ["-l"]
          }
        },
        "terminal.integrated.defaultProfile.linux": "bash (onboard)"
      }
    }
  }
}
