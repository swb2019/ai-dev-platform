{
  "extends": [
    "@ai-dev-platform/eslint-config-custom/next"
  ],
  "parserOptions": {
    "project": "./tsconfig.json",
    "tsconfigRootDir": "."
  },
  "settings": {
    "import/resolver": {
      "typescript": {
        "project": "./tsconfig.json"
      }
    }
  },
  "rules": {
    "@next/next/no-html-link-for-pages": ["error", "src/app"]
  }
}