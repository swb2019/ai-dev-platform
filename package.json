{
  "name": "ai-dev-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered development platform with security-first architecture",
  "engines": {
    "node": "^20.0.0",
    "pnpm": "^9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "build:api": "pnpm --filter @ai-dev-platform/api-gateway build",
    "build:web": "pnpm --filter @ai-dev-platform/web build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:api": "pnpm --filter @ai-dev-platform/api-gateway lint",
    "lint:web": "pnpm --filter @ai-dev-platform/web lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:api": "pnpm --filter @ai-dev-platform/api-gateway test",
    "test:web": "pnpm --filter @ai-dev-platform/web test",
    "test:watch": "turbo run test:watch",
    "type-check": "turbo run type-check",
    "type-check:api": "pnpm --filter @ai-dev-platform/api-gateway type-check",
    "type-check:web": "pnpm --filter @ai-dev-platform/web type-check",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "pnpm exec husky",
    "docker:build:web": "bash ./scripts/container/supply-chain.sh build --service web",
    "docker:scan:web": "bash ./scripts/container/supply-chain.sh scan --service web",
    "docker:sbom:web": "bash ./scripts/container/supply-chain.sh sbom --service web",
    "docker:sign:web": "COSIGN_EXPERIMENTAL=1 bash ./scripts/container/supply-chain.sh sign --service web --file artifacts/sbom-web-cyclonedx.json",
    "docker:sign:sbom": "pnpm docker:sign:web",
    "docker:build:api": "bash ./scripts/container/supply-chain.sh build --service api-gateway",
    "docker:scan:api": "bash ./scripts/container/supply-chain.sh scan --service api-gateway",
    "docker:sbom:api": "bash ./scripts/container/supply-chain.sh sbom --service api-gateway",
    "docker:sign:api": "COSIGN_EXPERIMENTAL=1 bash ./scripts/container/supply-chain.sh sign --service api-gateway --file artifacts/sbom-api-gateway-cyclonedx.json"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@next/eslint-plugin-next": "^14.2.3",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-config-next": "^14.2.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^2.1.0",
    "eslint-plugin-sonarjs": "^0.23.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.1",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "cross-spawn": "7.0.5"
    }
  },
  "keywords": [
    "ai",
    "development",
    "platform",
    "security",
    "monorepo",
    "nextjs",
    "typescript"
  ],
  "author": "AI Dev Platform Team",
  "license": "MIT"
}
